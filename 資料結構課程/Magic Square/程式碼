	: TForm(Owner)
{  }
int square[21][21];


void MagicSquare(int n)
{
	int i,j,k,l,data;
	if  ((n>21)||(n<1))
	{		Form1->Memo1->Lines->Add("Unable to process.");
	return;
	}
	else if((n%2)==0)
	{   	Form1->Memo1->Lines->Add("Please input an odd number!");
		return;
	}
	for(i=0;i<n;i++){
		for(j=0;j<n;j++){
			square[i][j]=0 ;
		}
	}
	i=0;j=(n-1)/2;
	square[i][j]=1;
	data=2;
	while(data<=n*n)
	{   k=(i-1)<0? n-1:i-1;
		l=(j-1)<0? n-1:j-1;
		if(square[k][l]>0)
			i=(i+1)%n;
		else{
			i=k;
			j=l;
		}
	square[i][j]=data++;
	}
	 Form1->Memo1->Lines->Add("-------"+IntToStr(n)+"*"+n+"-------");
	 String array;
	for(i=0;i<n;i++){
		for(j=0;j<n;j++){
			array+=IntToStr(square[i][j])+"\t";
		}
		   array+="\r\n";
	}
	Form1->Memo1->Lines->Add(array);

}

