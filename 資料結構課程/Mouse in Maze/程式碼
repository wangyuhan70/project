void __fastcall TForm1::Button3Click(TObject *Sender)
{
struct position stack[MAX_SIZE*MAX_SIZE];
	int step=0, m, n, d, p, q, flag;

	path_traced=new int *[h+2];
	for(i=0;i<(h+2);i++)
		path_traced[i]=new int [w+2];
	for(i=0;i<(h+2);i++)
		for(j=0;j<(w+2);j++)
			path_traced[i][j]=0;     //init the copy maze for check

	m=1;
	n=0;
	step=0;//start
	do{
		p=m;
		q=n;//location and movement
		d=0;//first direction
		flag=0;//make sure is there a way
		while(d<=7)
		{
			p=m+move2[d].dx;
			q=n+move2[d].dy;
			if(path_traced[p][q]==0 && maze[p][q]==0)//==1 no way / been walked through
			{
				path_traced[p][q]=1;
				stack[step].x=p;
				stack[step].y=q;
				stack[step].dir=d;
				m=p;
				n=q;
				step+=1;
				flag=1;//there is a way
				d=0;
				break;
			}
			d+=1;
		}

		if(flag==0)//no way out ->back to previous step
		{
			step-=1;
			if(step==-1)
			{
				Form1->Memo1->Lines->Add("THERE IS NO WAY OUT!");
				break;
			}
			m=m-move2[stack[step].dir].dx;
			n=n-move2[stack[step].dir].dy;
		}
	}while(stack[step-1].x!=h || stack[step-1].y!=w);//not yet walk to the end

	//update
	for(i=0;i<(h+2);i++)
	{
       for(j=0;j<(w+2);j++)
	   {
			if(path_traced[i][j]==1)
				maze[i][j]=3;//been walked
	   }
	}

	for(i=0;i<step;i++)
		maze[stack[i].x][stack[i].y]=4;//route

	if(step!=-1)
	{
		maze[h][w+1]=4;
        maze[1][0]=4;
    }


	Form1->Memo1->Lines->Add("=======Path("+IntToStr(h)+","+IntToStr(w)+")=======");
	for(i=0;i<(h+2);i++)
	{
		String s;
		for(j=0;j<(w+2);j++)
			s+="  "+IntToStr(maze[i][j]);
		Form1->Memo1->Lines->Add(s);
	}
	for(i=0;i<(h+2);i++)
	{
		 for(j=0;j<(w+2);j++)
		 {
			 StringGrid2->Cells[j][i] = maze[i][j];
			 StringGrid3->Cells[j][i] = maze[i][j];
         }

	}


}
