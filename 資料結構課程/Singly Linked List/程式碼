struct node{
	int data;
	struct node *next;
	struct node *link;
};

struct stacknode{
	int data;
	struct stacknode *link;
};

struct queuenode {
	int data;
	struct queuenode *next;
};



struct node *header;
struct node *first;
struct node *last;
struct stacknode *top;
struct queuenode *front ,*rear;



struct node *newnode(int element)
{
	struct node *p=new struct node;

	p->data=element;
	p->next=NULL;
	return p;
}

struct stacknode *newnodenode(int element)
{
	stacknode *p=new struct stacknode;

	if(p==NULL)
	{
		Form1->Memo1->Lines->Add("memory not enough");
	}
	else{
		p->data=element;
		p->link=NULL;
		return p;
    }



}

struct queuenode *newnodex(char element)
{
	struct queuenode *p;
	p=new struct queuenode;

	p->data=element;
	p->next=NULL;
	return p;
}

void push(int element)
{
	stacknode *x;
	x=newnodenode(element);
	if(top==NULL)
		top =x;
	else {
		x->link =top;
		top=x;
	}

}





void insertfirst(node *p,int element)
{
	struct node *x;
	x=new struct node;

	if(p==NULL)
	{
	   x->data=element;
	   first=x;
	   x->next=NULL;
	}
	else
	{
    	x->data=first->data;
		first->data=element;
		x->next=p->next;
		p->next=x;
	}

}

void insertlast(node *p,int element)
{
	struct node *x;
	x=new struct node;
	x->data=element;
	x->next=NULL;

	if(p==NULL)
	{
	   first=x;
	   x->next=NULL;
	   return;

	}
	else{
		while(p->next!=NULL)
		{
			p=p->next;
		}
		p->next=x;
	}
	}

struct node* searchdata(int target)
{
	struct node *p;
	p=first;

	while((p!=NULL)&& (p->data!=target))
		p=p->next;
	return p;
}



void insertafter(struct node *p,int element)
{
	node *x=newnode(element);
	x->next=p->next;
	p->next=x;
}

void insertbefore(node *p,int element)
{
	int copy=p->data;
    p->data=element;
	node *x=newnode(copy);
	x->next=p->next;
	p->next=x;

}


int searchanddelete(int target)
{
	node *p,*q;
	p=first;
	q=NULL;
	while((p!=NULL)&& (p->data !=target))
	{
		q=p;
		p=p->next;
	}
	if(p==NULL)
		return -1;
	if(p==first)
		first=p->next;
	else q->next=p->next;
	free(p);
	return target;
}

void insertqueue(char element)
{
	struct queuenode *p;
	p=newnodex(element);
	if(rear==NULL)
		front=p;
	else
		rear->next=p;
        rear=p;
}

int deletequeue()
{
	queuenode *p;
	int element;
	if(front==NULL)
	{
        rear=NULL;
		return -1;
	}
	else
	{
		p=front;
		front=front->next;
		element=p->data;
		free(p);
		return element;
	}

}



void printlist(node *first)
{
	struct node *p;
	String list ="";
	for ((p=first); p!=NULL; p=p->next)
	{
	   list+=IntToStr(p->data)+"->";
	}
	Form1->Memo1->Lines->Add(list+"<");

}

void printstack(stacknode *first)
{
	struct stacknode *p;
	String list ="";
	for ((p=top); p!=NULL; p=p->link)
	{
	   list+=IntToStr(p->data)+"->";
	}
	Form1->Memo1->Lines->Add(list+"<");

}

void printqueue(queuenode *f)
{
	struct queuenode *p;
	String list ="";
	for ((p=f); p!=NULL; p=p->next)
	{
	   list+=IntToStr(p->data)+"->";
	}
	Form1->Memo1->Lines->Add(list+"<");

}



 int pop()
{
	stacknode *p;
	if(top==NULL)
	{
		Form1->Memo1->Lines->Add("stack is empty!");
	}
	else
	{
		p=top;
		top=top->link;
		int data=p->data;
		free(p);
		return data;
	}
}

void reverse(node *first)
 {
	 struct node *r,*s,*t;
	 r=first;
	 s=NULL;
	 while(r!=NULL)
	 {
		 t=s;
		 s=r;
		 r=r->next;
		 s->next=t;
	 }

	 first=s;
	 struct node *p;
	String list ="";
	for ((p=s); p!=NULL; p=p->next)
	{
	   list+=IntToStr(p->data)+"->";
	}
	Form1->Memo1->Lines->Add(list+"<");


 }



