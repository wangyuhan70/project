void SelectionSort(int data[],int n)
{
 int i,j,temp,min;

	for(i=0;i<n;i++)
	{
		min = i;

		for(j=i+1;j<n;j++)
		{
			if(data[j]<data[min])
			{
				min=j;
			}
		}

		SWAP(data[i],data[min],temp);
	}
}

void InsertionSort(int data[],int n)
{
 int i,j,target;

	for(i=1;i<n;i++)
	{
		target=data[i];
		j=i;
		while((j>0)&&(data[j-1]>target))
		{
			data[j]=data[j-1];
			j--;
		}
		data[j]=target;
	}
}

void BubbleSort(int data[],int n)
{
 int i,j,temp;

	for(i=n-1;i>=0;i--)
	{
		for(j=1;j<i+1;j++)
		{
			if(data[j-1]>data[j])
			{
				SWAP(data[j-1],data[j],temp);
			}
		}
	}
}

void QuickSortR(int data[],int left,int right)
{
  int i,j,target,temp;

	if(left<right)
	{
		i=left+1;
		j=right;
		target=data[left];

		do
		{
			while(data[i]<target && i<=j)
			{
				i++;
			}

			while(data[j]>=target && i<=j)
			{
				j--;
			}

			if(i<j)
			{
				SWAP(data[i],data[j],temp);
			}
		}while(i<j);

		if(left<j)
		{
			SWAP(data[left],data[j],temp);
		}

		QuickSortR(data,left,j-1);
		QuickSortR(data,j+1,right);
	}
}

void QuickSortNR(int data[], int left, int right)
{
   int i,j,target,temp;
	struct position element;
	element.left=left;
	element.right=right;
	push(element);

	while(top!=-1)
	{
		element=pop();
		left=element.left;
		right=element.right;
		target=data[left];
		i=left+1;
		j=right;

		do
		{
			while((data[i]<target)&&i<=j)
			{
				i++;
			}

			while((data[j]>=target)&&i<=j)
			{
				j--;
			}

			if(i<j)
			{
				SWAP(data[i],data[j],temp);
			}
		}while(i<j);

		if(left<j)
		{
			SWAP(data[left],data[j],temp);
		}
		if(j+1<right)
		{
			element.left=j+1;
			element.right=right;
			push(element);
		}
		if(left<j-1)
		{
			element.left=left;
			element.right=j-1;
			push(element);
		}
	}
}
void merge(int data[],int left,int right,int m)
{
    int n1=m-left+1;
	int n2=right-m;
	int* L=new int[n1];
	int* R=new int[n2];

	for(int i=0;i<n1;i++)
	{
		L[i]=data[left+i];
	}

	for(int i=0;i<n2;i++)
	{
		R[i]=data[i+m+1];
	}

	L[n1]=2147483647;
	R[n2]=2147483647;

	int i=0,j=0;

	for(int k=left;k<=right;k++)
	{
		if (L[i]<=R[j])
		{
			data[k]=L[i];
			i++;
		}
		else
		{
			data[k]=R[j];
			j++;
		}
	}
}
void MergeSortR(int data[],int left,int right)
{
	if (left<right)
	{
		int m=(left+right)/2;
		MergeSortR(data,left,m);
		MergeSortR(data,m+1,right);
		merge(data,left,right,m);
	}
}

void MergeSortNR(int data[],int n)
{
	int i,len=2;

	while(len<n)
	{
		for(i=0;i<n;i+=len)
		{
			merge(data,i,i+len/2,i+len/2-1);
		}
		len*=2;
	}
	if(len/2<n) merge(data,0,n-1,(n-1)/2);
}
void restore(int s,int t)
{
    int i=s,j,temp;

	while(i<=t/2)
	{
		if(heap[2*i]<heap[2*i+1])
		{
			j=2*i;
		}
		else
		{
			j=2*i+1;
		}
		if(heap[2*i+1]==0) j=2*i;
		if(heap[i]<heap[j])
		{
			break;
		}
		SWAP(heap[i],heap[j],temp);
		i=j;
	}
}
void HeapSort(int data[],int n)
{
	int i;
	heap = new int[n+1];
	for(i=1;i<=n;heap[i]=data[i-1],i++);
	for(i=n/2;i>=1;i--)
	{
		restore(i,n);
	}

	for(i=n;i>0;i--)
	{
		if(Form1->CheckBox1->Checked) Form1->Memo9->Lines->Add("data["+IntToStr(n-i-1)+"] = "+IntToStr(heap[1]));
		heap[1]=heap[i];
		restore(1,i-1);
	}
}
