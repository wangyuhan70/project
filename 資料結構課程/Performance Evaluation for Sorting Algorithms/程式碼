struct position
{
	int left,right;
};
struct position stack[10000000];

void push(struct position element)
{
	stack[++top]=element;
}



struct position pop()
{
	struct position element;

	if(top==-1)
	{
		ShowMessage("Stack Empty");
	}
	else
	{
		element=stack[top--];
		return element;
	}
}

